# ── API Keys ──────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) - Free
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub - Free tier (60 calls/min)
# https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI - Free tier (100 calls/day)
# https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# Reddit API (PRAW) - Free
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=USMarketDashboard/1.0

# OpenAI (for news summarization) - Paid
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# StockTwits - Free (public API, no key needed for public streams)
# No key required

# Polygon.io - Free tier (5 calls/min)
# https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here
